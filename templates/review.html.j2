<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ site.name }} Profile & ScamFactor Score | SafeTracker: Sweepstakes</title>
  <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1">
  <link rel="canonical" href="https://sweeps.safetrackerhub.com/reviews/{{ site.slug }}">
  <link rel="icon" type="image/png" href="../assets/safetracker-icon.png">
  <meta name="description" content="{{ site.name }} inventory profile: ScamFactor score, known prizes, entry frequency, unsubscribe instructions, evidence, and major concerns.">
  <script type="application/ld+json">
  {"@context":"https://schema.org","@graph":[
    {"@type":"WebPage","@id":"https://sweeps.safetrackerhub.com/reviews/{{ site.slug }}#page","url":"https://sweeps.safetrackerhub.com/reviews/{{ site.slug }}","name":"{{ site.name }} inventory profile and ScamFactor score","dateModified":"{{ last_updated_iso }}","isPartOf":{"@id":"https://sweeps.safetrackerhub.com/#website"}},
    {"@type":"BreadcrumbList","itemListElement":[
      {"@type":"ListItem","position":1,"name":"SafeTracker: Sweepstakes","item":"https://sweeps.safetrackerhub.com/"},
      {"@type":"ListItem","position":2,"name":"Sweepstakes site rankings","item":"https://sweeps.safetrackerhub.com/#rankings"},
      {"@type":"ListItem","position":3,"name":"{{ site.name }}","item":"https://sweeps.safetrackerhub.com/reviews/{{ site.slug }}"}
    ]}
  ]}</script>
  <link rel="stylesheet" href="../assets/site.css">
</head>
<body>
  <header class="site-header review-site-header">
    <div class="review-shell review-masthead">
      <a class="review-brand" href="../index.html">← SafeTracker: Sweepstakes</a>
      <span>Reviewed {{ last_updated }}</span>
    </div>
  </header>

  <main class="review-shell review-main">
    <nav class="review-breadcrumb" aria-label="Breadcrumb"><a href="../index.html">Sweepstakes rankings</a><span>/</span><span>{{ site.name }}</span></nav>

    <section class="review-hero">
      <div class="review-identity">
        {% if site.logo_asset %}
        <span class="site-logo-panel">
          <img src="../{{ site.logo_asset }}" alt="{{ site.name }} logo">
        </span>
        {% else %}
        <span class="site-mark site-mark-large" style="--site-mark-hue: {{ site.mark_hue }}" aria-hidden="true">
          <span class="site-mark-fallback">{{ site.initials }}</span>
          {% if site.link and site.link != "#" %}
            <img class="site-mark-image" src="{{ site.favicon_url }}" alt="" width="48" height="48" onerror="this.remove()">
          {% endif %}
        </span>
        {% endif %}
        <div class="review-nameplate">
          <div class="review-nameplate-top">
            <span class="profile-number">#{{ "%02d"|format(site.rank) }}</span>
            <span class="profile-label">SafeTracker inventory card</span>
            <a class="category-badge review-type-pill" href="../site-types.html#{{ site.theme|default('other') }}">{{ site.theme|default('Sweepstakes site')|replace('-', ' ') }}</a>
          </div>
          <h1>{{ site.name }}</h1>
          <p class="review-deck">Prize inventory, entry frequency, unsubscribe options, and the risk signals behind its score.</p>
        </div>
      </div>
      <div class="review-score-card">
        <img class="review-score-stamp" src="../assets/scamfactor-stamp.png" alt="ScamFactor">
        <div class="score-dial" style="--score: {{ site.score }}" role="img" aria-label="ScamFactor {{ site.score }} out of 10, where green is lower concern and red is higher concern">
          <div class="score-dial-arc"></div>
          <div class="score-dial-needle"></div>
        </div>
        <div class="score-dial-labels"><span>Lower concern</span><span>Higher concern</span></div>
        <strong>{{ site.score }}</strong>
        <span>out of 10 · lower is better</span>
      </div>
    </section>

    <div class="review-layout">
      <article class="review-article">
        <section class="review-section">
          <h2>Inventory record</h2>
          <dl class="review-facts">
            <div><dt>Tracker rank</dt><dd>#{{ site.rank }}</dd></div>
            <div><dt>Site type</dt><dd><a href="../site-types.html#{{ site.theme|default('other') }}">{{ site.theme|default('Other')|replace('-', ' ') }}</a></dd></div>
            <div><dt>Profile refreshed</dt><dd>{{ site.profile_refresh.checked_at[:10]|default(last_updated) }}</dd></div>
            <div><dt>Public source status</dt><dd>{{ site.profile_refresh.status|default('not checked')|replace('_', ' ') }}</dd></div>
            <div><dt>Entry and drawing schedule</dt><dd>{{ site.draw }}</dd></div>
            <div><dt>Eligibility</dt><dd>{{ site.eligibility|default('Varies by promotion; verify the official rules before entering.') }}</dd></div>
            <div><dt>Account or entry requirements</dt><dd>{{ site.entry_requirements|default('Requirements vary by promotion and may include email registration or a site account.') }}</dd></div>
            <div><dt>Winner evidence</dt><dd>{{ site.winner_evidence|default('Check the operator or individual sponsor for a current winners list and fulfillment evidence.') }}</dd></div>
          </dl>
        </section>

        <section class="review-section prize-section">
          <div class="review-section-heading">
            <div><p class="section-kicker">Publicly identified inventory</p><h2>Known prizes</h2></div>
            <span>{{ site.prize_items|length }} recorded item{% if site.prize_items|length != 1 %}s{% endif %}</span>
          </div>
          <ul class="prize-list">
            {% for prize in site.prize_items %}
            <li>
              <div class="prize-card-head">
                <strong>{{ prize.label }}</strong>
                {% if prize.entry_url %}<a class="prize-entry-link" href="{{ prize.entry_url }}" target="_blank" rel="noopener sponsored">Enter here →</a>{% endif %}
              </div>
              <dl class="prize-meta">
                <div><dt>Listing status</dt><dd>{{ prize.status|default('Known when last verified') }}</dd></div>
                <div><dt>Entry frequency</dt><dd>{{ prize.entry_frequency|default('Not yet recorded; verify the official rules.') }}</dd></div>
                <div><dt>Login required?</dt><dd>{{ prize.login_required }}</dd></div>
                <div><dt>Last publicly reported win</dt><dd>{{ prize.last_won }}</dd></div>
                <div><dt>Next drawing</dt><dd>{{ prize.next_drawing }}</dd></div>
                {% if prize.last_verified %}<div><dt>Last verified</dt><dd>{{ prize.last_verified[:10] }}</dd></div>{% endif %}
              </dl>
            </li>
            {% endfor %}
          </ul>
          {% if site.link and site.link != "#" %}<a class="browse-prizes-link" href="{{ site.link }}" target="_blank" rel="noopener sponsored">Browse current prizes on the official site →</a>{% endif %}
          <p class="inventory-caveat">Prize availability, entry limits, winner reports, and drawing dates change. “Not publicly stated” means we did not find a reliable public value; it does not mean no drawing is scheduled. Some operators may reveal additional prizes or timing only after sign-in.</p>
        </section>

        <section class="review-section">
          <h2>Pros and cons at a glance</h2>
          <div class="pros-cons-grid">
            <div class="pros-panel">
              <h3>Potential advantages</h3>
              <ul>{% for item in site.pros|default([
                'Ranks #' ~ site.rank ~ ' in the current SafeTracker inventory with a ' ~ site.score ~ '/10 ScamFactor score.',
                site.prizes,
                site.draw
              ]) %}<li>{{ item }}</li>{% endfor %}</ul>
            </div>
            <div class="cons-panel">
              <h3>Tradeoffs to consider</h3>
              <ul>{% for item in site.cons|default([
                site.redFlags,
                'Eligibility, entry limits, and data terms may vary by individual promotion.',
                'Winning is never guaranteed; verify the current official rules before entering.'
              ]) %}<li>{{ item }}</li>{% endfor %}</ul>
            </div>
          </div>
        </section>

        <section class="review-section concern-section">
          <p class="section-kicker">Risk detail</p>
          <h2>Main concerns and scored signals</h2>
          <p class="concern-lead">{{ site.redFlags }}</p>
          <div class="risk-signal-grid">
            {% for signal in site.risk_signals %}
            <div>
              <span>{{ signal.label }}</span>
              <strong>{{ "%.1f"|format(signal.score) }}/10</strong>
              <small>{{ signal.assessment }}</small>
            </div>
            {% endfor %}
          </div>
          <p class="inventory-caveat">These signals explain the displayed ScamFactor score. They summarize available evidence and consumer friction; they do not label every promotion on the platform as safe or unsafe.</p>
        </section>

        <section class="review-section">
          <h2>Marketing and data practices</h2>
          <dl class="review-facts">
            <div><dt>Marketing intensity</dt><dd>{{ site.marketing_intensity|default('Not independently measured; use a dedicated sweepstakes email address.') }}</dd></div>
            <div><dt>Data handling</dt><dd>{{ site.data_practices|default('Review the site and each outside sponsor’s privacy terms before submitting personal information.') }}</dd></div>
            <div><dt>Paid placement status</dt><dd>{{ site.placement_status|default('Not currently labeled as sponsored.') }}</dd></div>
          </dl>
        </section>

        <section id="unsubscribe" class="review-section unsubscribe-section">
          <h2>How to unsubscribe</h2>
          <p>{{ site.unsub }}</p>
          <div class="review-actions">
            {% if site.unsubscribe_url %}<a class="review-button" href="{{ site.unsubscribe_url }}" target="_blank" rel="noopener">{{ site.unsubscribe_label|default('Open unsubscribe page') }} →</a>{% endif %}
            {% if site.privacy_opt_out_url %}<a class="review-button secondary" href="{{ site.privacy_opt_out_url }}" target="_blank" rel="noopener">Open privacy opt-out →</a>{% endif %}
            {% if site.unsubscribe_help_url %}<a class="review-button secondary" href="{{ site.unsubscribe_help_url }}" target="_blank" rel="noopener">Official instructions →</a>{% endif %}
          </div>
        </section>

        <section class="review-section">
          <h2>What this score means</h2>
          <p><img class="inline-scamfactor-stamp" src="../assets/scamfactor-stamp.png" alt="ScamFactor"> estimates consumer risk and friction; it does not predict whether you will win. It considers transparency, winner and fulfillment evidence, entry requirements, realistic opportunity, complaints, and marketing pressure.</p>
          <a class="text-link" href="../methodology.html">Read the complete scoring methodology →</a>
        </section>

        <section class="review-section">
          <h2>Source and verification links</h2>
          <div class="source-list">
            {% if site.link and site.link != "#" %}<a href="{{ site.link }}" target="_blank" rel="noopener">Official website</a>{% endif %}
            {% if site.scrape_url %}<a href="{{ site.scrape_url }}" target="_blank" rel="noopener">Page checked for tracker data</a>{% endif %}
            {% if site.unsubscribe_url %}<a href="{{ site.unsubscribe_url }}" target="_blank" rel="noopener">Email unsubscribe page</a>{% endif %}
            {% if site.privacy_opt_out_url %}<a href="{{ site.privacy_opt_out_url }}" target="_blank" rel="noopener">Privacy-rights request</a>{% endif %}
            {% if site.unsubscribe_help_url %}<a href="{{ site.unsubscribe_help_url }}" target="_blank" rel="noopener">Official unsubscribe instructions</a>{% endif %}
          </div>
          <p class="verification-note">The automated public-source check last ran {{ site.profile_refresh.checked_at[:10]|default(last_updated) }} with status “{{ site.profile_refresh.status|default('not checked')|replace('_', ' ') }}.” Missing fields are intentionally identified rather than guessed, and protected or member-only pages remain subject to manual review.</p>
        </section>
      </article>

      <aside class="review-sidebar">
        <div class="review-sidebar-card">
          <h2>Visit or compare</h2>
          {% if site.link and site.link != "#" %}<a class="review-primary-action" href="{{ site.link }}" target="_blank" rel="noopener sponsored">Visit official site →</a>{% endif %}
          <a class="review-secondary-action" href="../index.html#rankings">Compare all sites</a>
          <p>Links or featured placement may be sponsored. The displayed score remains visible regardless of placement.</p>
        </div>
      </aside>
    </div>
  </main>

  <footer class="site-footer">
    <div class="review-shell footer-bottom"><span>SafeTracker: Sweepstakes · Verify official rules before entering · Never pay to claim a prize.</span><span class="site-version">v1.2</span></div>
  </footer>
</body>
</html>
