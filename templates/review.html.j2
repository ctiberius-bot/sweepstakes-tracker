<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ site.name }} Sweepstakes Site Profile | SafeTrackerHub</title>
  <meta name="description" content="{{ site.name }} site profile: ScamFactor score, prize examples, entry frequency, unsubscribe instructions, and major red flags.">
  <link rel="stylesheet" href="../assets/site.css">
</head>
<body>
  <header class="site-header review-site-header">
    <div class="review-shell review-masthead">
      <a class="review-brand" href="../index.html">← SafeTrackerHub rankings</a>
      <span>Reviewed {{ last_updated }}</span>
    </div>
  </header>

  <main class="review-shell review-main">
    <nav class="review-breadcrumb" aria-label="Breadcrumb"><a href="../index.html">Sweepstakes tracker</a><span>/</span><span>{{ site.name }}</span></nav>

    <section class="review-hero">
      <div>
        {% if site.link and site.link != "#" %}
          <img class="review-favicon" src="{{ site.link.rstrip('/') }}/favicon.ico" alt="" width="48" height="48" onerror="this.remove()">
        {% endif %}
        <p class="section-kicker">{{ site.theme|default('Sweepstakes site')|replace('-', ' ') }}</p>
        <h1>{{ site.name }} site profile</h1>
        <p class="review-deck">Prize examples, entry frequency, unsubscribe options, and the risk signals behind its score.</p>
      </div>
      <div class="review-score-card">
        <img class="review-score-stamp" src="../assets/scamfactor-stamp.png" alt="ScamFactor">
        <strong>{{ site.score }}</strong>
        <span>out of 10 · lower is better</span>
      </div>
    </section>

    <div class="review-layout">
      <article class="review-article">
        <section class="review-section">
          <h2>Inventory record</h2>
          <dl class="review-facts">
            <div><dt>Tracker rank</dt><dd>#{{ site.rank }}</dd></div>
            <div><dt>Site type</dt><dd>{{ site.theme|default('Other')|replace('-', ' ') }}</dd></div>
            <div><dt>Last verified</dt><dd>{{ last_updated }}</dd></div>
            <div><dt>Current status</dt><dd>Active when last checked</dd></div>
            <div><dt>Entry and drawing schedule</dt><dd>{{ site.draw }}</dd></div>
            <div><dt>Eligibility</dt><dd>{{ site.eligibility|default('Varies by promotion; verify the official rules before entering.') }}</dd></div>
            <div><dt>Account or entry requirements</dt><dd>{{ site.entry_requirements|default('Requirements vary by promotion and may include email registration or a site account.') }}</dd></div>
            <div><dt>Winner evidence</dt><dd>{{ site.winner_evidence|default('Check the operator or individual sponsor for a current winners list and fulfillment evidence.') }}</dd></div>
          </dl>
        </section>

        <section class="review-section">
          <h2>Prize examples</h2>
          <p>{{ site.prizes }}</p>
        </section>

        <section class="review-section concern-section">
          <h2>Main concerns and tradeoffs</h2>
          <p>{{ site.redFlags }}</p>
        </section>

        <section class="review-section">
          <h2>Marketing and data practices</h2>
          <dl class="review-facts">
            <div><dt>Marketing intensity</dt><dd>{{ site.marketing_intensity|default('Not independently measured; use a dedicated sweepstakes email address.') }}</dd></div>
            <div><dt>Data handling</dt><dd>{{ site.data_practices|default('Review the site and each outside sponsor’s privacy terms before submitting personal information.') }}</dd></div>
            <div><dt>Paid placement status</dt><dd>{{ site.placement_status|default('Not currently labeled as sponsored.') }}</dd></div>
          </dl>
        </section>

        <section class="review-section">
          <h2>How to unsubscribe</h2>
          <p>{{ site.unsub }}</p>
          <div class="review-actions">
            {% if site.unsubscribe_url %}<a class="review-button" href="{{ site.unsubscribe_url }}" target="_blank" rel="noopener">Open unsubscribe page →</a>{% endif %}
            {% if site.privacy_opt_out_url %}<a class="review-button secondary" href="{{ site.privacy_opt_out_url }}" target="_blank" rel="noopener">Open privacy opt-out →</a>{% endif %}
          </div>
        </section>

        <section class="review-section">
          <h2>What this score means</h2>
          <p><img class="inline-scamfactor-stamp" src="../assets/scamfactor-stamp.png" alt="ScamFactor"> estimates consumer risk and friction; it does not predict whether you will win. It considers transparency, winner and fulfillment evidence, entry requirements, realistic opportunity, complaints, and marketing pressure.</p>
          <a class="text-link" href="../index.html#methodology">Read the complete scoring methodology →</a>
        </section>

        <section class="review-section">
          <h2>Source and verification links</h2>
          <div class="source-list">
            {% if site.link and site.link != "#" %}<a href="{{ site.link }}" target="_blank" rel="noopener">Official website</a>{% endif %}
            {% if site.scrape_url %}<a href="{{ site.scrape_url }}" target="_blank" rel="noopener">Page checked for tracker data</a>{% endif %}
            {% if site.unsubscribe_url %}<a href="{{ site.unsubscribe_url }}" target="_blank" rel="noopener">Email unsubscribe page</a>{% endif %}
            {% if site.privacy_opt_out_url %}<a href="{{ site.privacy_opt_out_url }}" target="_blank" rel="noopener">Privacy-rights request</a>{% endif %}
          </div>
          <p class="verification-note">This inventory record was last refreshed {{ last_updated }}. Missing fields are intentionally identified rather than guessed.</p>
        </section>
      </article>

      <aside class="review-sidebar">
        <div class="review-sidebar-card">
          <h2>Visit or compare</h2>
          {% if site.link and site.link != "#" %}<a class="review-primary-action" href="{{ site.link }}" target="_blank" rel="noopener sponsored">Visit official site →</a>{% endif %}
          <a class="review-secondary-action" href="../index.html#rankings">Compare all sites</a>
          <p>Links or featured placement may be sponsored. The displayed score remains visible regardless of placement.</p>
        </div>
      </aside>
    </div>
  </main>

  <footer class="site-footer">
    <div class="review-shell footer-bottom">SafeTrackerHub · Verify official rules before entering · Never pay to claim a prize.</div>
  </footer>
</body>
</html>
