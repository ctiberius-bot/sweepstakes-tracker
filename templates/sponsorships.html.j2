<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Advertise with SafeTracker: Sweepstakes</title>
  <meta name="description" content="Reserve labeled featured placement, category sponsorship, or a custom campaign on SafeTracker: Sweepstakes.">
  <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1">
  <link rel="canonical" href="https://sweeps.safetrackerhub.com/sponsorships">
  <link rel="icon" type="image/png" href="assets/safetracker-icon.png">
  <link rel="stylesheet" href="assets/site.css">
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" defer></script>
</head>
<body>
  <header class="site-header review-site-header">
    <div class="review-shell review-masthead"><a class="review-brand" href="/">← SafeTracker: Sweepstakes</a><span>Advertising and partnerships</span></div>
  </header>
  <main class="review-shell sponsor-page">
    <nav class="review-breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span>/</span><span>Advertise</span></nav>

    <section class="sponsor-hero sponsor-sales-hero">
      <div>
        <p class="section-kicker">Founding partner inventory is open</p>
        <h1>Own the placement comparison-minded sweepstakes visitors see first.</h1>
        <p>Reserve clearly labeled visibility on the tracker, individual site profiles, and the weekly winner email. A sponsor can buy prominence; the site’s displayed <img class="inline-scamfactor-stamp" src="assets/scamfactor-stamp.png" alt="ScamFactor"> score remains visible.</p>
        <a class="review-primary-action" href="#reserve" data-track="sponsor_interest" data-placement="hero">Request availability →</a>
      </div>
      <aside class="founding-offer">
        <span>Launch offer</span>
        <strong>50% off the first month</strong>
        <p>Available to the first three founding partners. No long-term contract required.</p>
      </aside>
    </section>

    <section class="sponsor-rate-card" aria-labelledby="rate-card-title">
      <div class="sponsor-section-heading">
        <p class="section-kicker">Simple launch pricing</p>
        <h2 id="rate-card-title">Choose a placement. Start quickly.</h2>
        <p>Introductory pricing may change as verified audience and conversion data grows.</p>
      </div>
      <div class="rate-grid">
        <article class="rate-card">
          <span class="rate-label">Fast test</span><h3>Featured site</h3><div class="rate-price">$149 <small>/ 7 days</small></div>
          <ul><li>Labeled homepage placement</li><li>Official-site call to action</li><li>Profile-page visibility</li><li>Click summary after the campaign</li></ul>
          <a href="#reserve" data-package="Featured site — 7 days" data-track="sponsor_package" class="rate-action">Select this package</a>
        </article>
        <article class="rate-card rate-card-featured">
          <span class="rate-label">Best launch value</span><h3>Featured site</h3><div class="rate-price">$399 <small>/ month</small></div>
          <ul><li>Everything in the 7-day test</li><li>Priority homepage visibility</li><li>One approved message refresh</li><li>Monthly click and placement summary</li></ul>
          <a href="#reserve" data-package="Featured site — monthly" data-track="sponsor_package" class="rate-action">Select this package</a>
        </article>
        <article class="rate-card">
          <span class="rate-label">Category ownership</span><h3>Category sponsor</h3><div class="rate-price">$699 <small>/ month</small></div>
          <ul><li>Category-level sponsor label</li><li>Featured card and profile visibility</li><li>Weekly email placement when sent</li><li>Campaign performance summary</li></ul>
          <a href="#reserve" data-package="Category sponsor" data-track="sponsor_package" class="rate-action">Select this package</a>
        </article>
        <article class="rate-card">
          <span class="rate-label">Maximum visibility</span><h3>Homepage takeover</h3><div class="rate-price">$1,250 <small>/ month</small></div>
          <ul><li>Exclusive top sponsor treatment</li><li>Category and profile visibility</li><li>Weekly email placement when sent</li><li>Custom campaign reporting</li></ul>
          <a href="#reserve" data-package="Homepage takeover" data-track="sponsor_package" class="rate-action">Check availability</a>
        </article>
      </div>
    </section>

    <section class="sponsor-details">
      <div><p class="section-kicker">What partners receive</p><h2>Useful visibility, not a disguised score change.</h2></div>
      <ul>
        <li>Prominent placement with a visible “Sponsored” or “Featured partner” label</li>
        <li>Links to an approved official landing page</li>
        <li>Placement beside useful inventory and safety information</li>
        <li>Tracked impressions, outbound clicks, and sponsor inquiries where available</li>
        <li>Flexible campaign timing with no automatic renewal during the launch period</li>
      </ul>
    </section>

    <section class="sponsor-standards">
      <h2>Commercial terms</h2>
      <p>Payment buys placement and exposure, not removal of disclosed risk information. Creative and landing pages must accurately describe the offer. SafeTracker may reject campaigns involving deceptive prize claims, hidden charges, malware, impersonation, or unlawful activity. Final availability, invoicing, payment method, and launch date are confirmed before a campaign begins.</p>
    </section>

    <section id="reserve" class="sponsor-inquiry">
      <div>
        <p class="section-kicker">Reserve a launch slot</p>
        <h2>Tell us what you want to promote.</h2>
        <p>Submit the site, preferred package, dates, and budget. This is an inquiry, not a purchase; payment instructions will be provided after fit and availability are confirmed.</p>
      </div>
      <section class="contact-card" aria-labelledby="sponsor-form-title">
        <h2 id="sponsor-form-title">Sponsorship inquiry</h2>
        <form id="sponsor-form" action="/api/contact" method="post">
          <div class="contact-field"><label for="sponsor-name">Your name</label><input id="sponsor-name" name="name" type="text" maxlength="100" autocomplete="name" required></div>
          <div class="contact-field"><label for="sponsor-email">Business email</label><input id="sponsor-email" name="email" type="email" maxlength="254" autocomplete="email" required></div>
          <div class="contact-field"><label for="sponsor-company">Company or site</label><input id="sponsor-company" name="company" type="text" maxlength="150" autocomplete="organization" required></div>
          <div class="contact-field"><label for="sponsor-url">Public website</label><input id="sponsor-url" name="source_url" type="url" maxlength="500" inputmode="url" placeholder="https://" required></div>
          <div class="contact-field"><label for="sponsor-package">Preferred package</label>
            <select id="sponsor-package" name="package" required>
              <option value="">Choose one</option>
              <option>Featured site — 7 days ($149)</option>
              <option>Featured site — monthly ($399)</option>
              <option>Category sponsor ($699/month)</option>
              <option>Homepage takeover ($1,250/month)</option>
              <option>Affiliate or performance partnership</option>
              <option>Custom campaign</option>
            </select>
          </div>
          <div class="sponsor-form-row">
            <div class="contact-field"><label for="sponsor-dates">Preferred dates</label><input id="sponsor-dates" name="dates" type="text" maxlength="100" placeholder="As soon as possible"></div>
            <div class="contact-field"><label for="sponsor-budget">Budget</label><select id="sponsor-budget" name="budget"><option>Under $250</option><option>$250–$500</option><option>$500–$1,000</option><option>$1,000–$2,500</option><option>$2,500+</option></select></div>
          </div>
          <div class="contact-field"><label for="sponsor-notes">Campaign notes</label><textarea id="sponsor-notes" name="notes" maxlength="3000" rows="5" placeholder="Offer, audience, landing page, goals, or anything we should know."></textarea></div>
          <input name="topic" type="hidden" value="business"><input name="message" type="hidden"><input id="sponsor-form-started-at" name="form_started_at" type="hidden">
          <div class="contact-trap" aria-hidden="true"><label for="sponsor-company-url">Company website</label><input id="sponsor-company-url" name="company_url" type="text" tabindex="-1" autocomplete="off"></div>
          <div id="sponsor-turnstile" class="turnstile-shell" aria-label="Human verification"></div>
          <p id="sponsor-status" class="contact-status" role="status" aria-live="polite">Loading secure verification…</p>
          <button id="sponsor-submit" class="review-primary-action contact-submit" type="submit" disabled>Request availability</button>
          <p class="contact-privacy">Submitting this form does not reserve inventory or create a payment obligation.</p>
        </form>
      </section>
    </section>
  </main>
  <footer class="site-footer"><div class="review-shell footer-bottom"><span>SafeTracker: Sweepstakes · Sponsorship information refreshed {{ last_updated }}.</span><span class="site-version">v1.2</span></div></footer>
  <script src="assets/sponsor.js"></script>
  <script src="assets/monetization.js"></script>
</body>
</html>
