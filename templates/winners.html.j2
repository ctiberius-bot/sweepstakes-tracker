<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="New sweepstakes winner reports gathered from original sweepstakes sites and communities.">
  <title>Winner Archive | SafeTracker: Sweepstakes</title>
  <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1">
  <link rel="canonical" href="https://sweeps.safetrackerhub.com/winners">
  <link rel="icon" type="image/png" href="assets/safetracker-icon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="assets/site.css">
</head>
<body>
  <header class="site-header review-site-header">
    <div class="review-shell review-masthead">
      <a class="review-brand" href="index.html">← SafeTracker: Sweepstakes</a>
      <span>Searchable historical archive · v1.1</span>
    </div>
  </header>
  <main class="review-shell winners-page">
    <section class="winners-hero">
      <div>
        <p class="section-kicker">Reported by monitored sources</p>
        <h1>Winner archive</h1>
        <p class="winners-intro">A searchable, persistent history of published winner reports. Every record carries its source and distinguishes community reports from operator announcements.</p>
      </div>
      <aside class="newsletter-card">
        <h2>Get new reports by email</h2>
        <p>One daily roundup when new reports are available. No empty editions.</p>
        <form class="newsletter-form" action="https://buttondown.com/api/emails/embed-subscribe/safetrackerhub" method="post">
          <div class="newsletter-fields">
            <label class="sr-only" for="winners-email">Email address</label>
            <input id="winners-email" type="email" name="email" autocomplete="email" placeholder="you@example.com" required>
            <input type="hidden" name="embed" value="1">
            <input type="hidden" name="tag" value="daily-winners">
            <button type="submit">Subscribe</button>
          </div>
          <span class="newsletter-privacy">Free. Unsubscribe anytime.</span>
        </form>
      </aside>
    </section>
    <section class="winner-search-panel" aria-label="Search winner archive">
      <label class="search-wrap"><span>Search the archive</span><input id="winner-search" class="control" type="search" placeholder="Winner, prize, promotion, operator, or source…"></label>
      <p id="winner-results-count" class="results-count" aria-live="polite">{{ winners|length }} report{% if winners|length != 1 %}s{% endif %}</p>
    </section>
    {% if winners %}
    <section id="winner-list" class="winner-list" aria-label="Winner reports">
      {% for winner in winners %}
      <article class="winner-card" data-winner-search="{{ [winner.title, winner.winner_name, winner.privacy_label, winner.promotion_name, winner.prize, winner.operator, winner.source_name, winner.author]|join(' ')|lower }}">
        <h2>{{ winner.title }}</h2>
        <p class="winner-meta">{{ winner.source_type|replace('_', ' ')|title }} · {{ winner.source_name }}{% if winner.author %} · {{ winner.author }}{% endif %} · {{ winner.published_display }}</p>
        {% if winner.prize or winner.operator or winner.drawing_date %}
        <dl class="winner-facts">
          {% if winner.prize %}<div><dt>Prize</dt><dd>{{ winner.prize }}</dd></div>{% endif %}
          {% if winner.operator %}<div><dt>Operator</dt><dd>{{ winner.operator }}</dd></div>{% endif %}
          {% if winner.drawing_date %}<div><dt>Drawing date</dt><dd>{{ winner.drawing_date }}</dd></div>{% endif %}
        </dl>
        {% endif %}
        <a class="winner-source" href="{{ winner.url }}" target="_blank" rel="noopener">View original report →</a>
      </article>
      {% endfor %}
    </section>
    {% else %}
    <section class="empty-winners">
      <h2>No new reports yet</h2>
      <p>The collector is watching the sources. New reports will appear here after the next daily check; we do not manufacture entries or send empty emails.</p>
    </section>
    {% endif %}
    <p class="source-note"><strong>Safety note:</strong> A winner report is not a request for payment. Legitimate prizes never require gift cards, wire transfers, or “processing fees.”</p>
  </main>
  <script>
    (() => {
      const search = document.querySelector("#winner-search");
      const cards = Array.from(document.querySelectorAll(".winner-card"));
      const count = document.querySelector("#winner-results-count");
      if (!search || !count) return;
      const update = () => {
        const query = search.value.trim().toLowerCase();
        let shown = 0;
        cards.forEach((card) => {
          const visible = !query || card.dataset.winnerSearch.includes(query);
          card.hidden = !visible;
          if (visible) shown += 1;
        });
        count.textContent = `${shown} report${shown === 1 ? "" : "s"}`;
      };
      search.addEventListener("input", update);
    })();
  </script>
</body>
</html>
