<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="New sweepstakes winner reports gathered from original sweepstakes sites and communities.">
  <title>Daily Sweepstakes Winners | SafeTrackerHub Sweepstakes</title>
  <link rel="canonical" href="https://sweeps.safetrackerhub.com/winners.html">
  <link rel="icon" type="image/png" href="assets/scamfactor-stamp.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="assets/site.css">
</head>
<body>
  <header class="site-header review-site-header">
    <div class="review-shell review-masthead">
      <a class="review-brand" href="index.html">← SafeTrackerHub Sweepstakes</a>
      <span>Source-linked winner reports</span>
    </div>
  </header>
  <main class="review-shell winners-page">
    <section class="winners-hero">
      <div>
        <p class="section-kicker">Reported by monitored sources</p>
        <h1>Daily sweepstakes winners</h1>
        <p class="winners-intro">A running list of newly published winner reports from the sweepstakes sites and communities we monitor. Every item links to its original report.</p>
      </div>
      <aside class="newsletter-card">
        <h2>Get new reports by email</h2>
        <p>One daily roundup when new reports are available. No empty editions.</p>
        <form class="newsletter-form" action="https://buttondown.com/api/emails/embed-subscribe/safetrackerhub" method="post">
          <div class="newsletter-fields">
            <label class="sr-only" for="winners-email">Email address</label>
            <input id="winners-email" type="email" name="email" autocomplete="email" placeholder="you@example.com" required>
            <input type="hidden" name="embed" value="1">
            <input type="hidden" name="tag" value="daily-winners">
            <button type="submit">Subscribe</button>
          </div>
          <span class="newsletter-privacy">Free. Unsubscribe anytime.</span>
        </form>
      </aside>
    </section>
    {% if winners %}
    <section class="winner-list" aria-label="Winner reports">
      {% for winner in winners %}
      <article class="winner-card">
        <h2>{{ winner.title }}</h2>
        <p class="winner-meta">Reported by {{ winner.source_name }}{% if winner.author %} · {{ winner.author }}{% endif %} · {{ winner.published_display }}</p>
        <a class="winner-source" href="{{ winner.url }}" target="_blank" rel="noopener">View original report →</a>
      </article>
      {% endfor %}
    </section>
    {% else %}
    <section class="empty-winners">
      <h2>No new reports yet</h2>
      <p>The collector is watching the sources. New reports will appear here after the next daily check; we do not manufacture entries or send empty emails.</p>
    </section>
    {% endif %}
    <p class="source-note"><strong>Safety note:</strong> A winner report is not a request for payment. Legitimate prizes never require gift cards, wire transfers, or “processing fees.”</p>
  </main>
</body>
</html>
