<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SweepSafe – Legit Sweepstakes Tracker</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    th { position:sticky; top:0; background:#134e4a; color:white; z-index:10; }
    tr:nth-child(even) { background:#f0fdfa; }

    /* ScamFactor logo style */
    .scamfactor-badge {
      display: inline-block;
      background: #dc2626;
      color: white;
      font-family: Impact, "Arial Black", sans-serif;
      font-size: 22px;
      font-weight: 900;
      letter-spacing: -1px;
      padding: 6px 16px;
      border: 4px solid #991b1b;
      border-radius: 6px;
      transform: rotate(-4deg);
      box-shadow: 3px 3px 0 #7f1d1d;
      line-height: 1;
      cursor: help;
    }

    /* Score pills */
    .score-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 2.4rem;
      height: 2rem;
      border-radius: 9999px;
      font-weight: 700;
      font-size: 0.9rem;
      border: 2px solid transparent;
      cursor: help;
    }
    .score-low    { background: #dcfce7; color: #166534; border-color: #86efac; }
    .score-midlow { background: #dbeafe; color: #1e40af; border-color: #93c5fd; }
    .score-mid    { background: #fef3c7; color: #92400e; border-color: #fcd34d; }
    .score-high   { background: #ffedd5; color: #9a3412; border-color: #fdba74; }
    .score-danger { background: #fee2e2; color: #991b1b; border-color: #fca5a5; }

    /* Simple tooltip enhancement */
    [title] {
      position: relative;
    }
  </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen">

  <header class="bg-gradient-to-r from-teal-800 to-teal-600 text-white shadow-lg">
    <div class="max-w-7xl mx-auto px-4 py-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <h1 class="text-2xl md:text-3xl font-bold flex items-center gap-2">
          <i class="fas fa-shield-alt"></i> SweepSafe Tracker
        </h1>
        <p class="text-teal-100 text-sm mt-1">
          Ranked by legitimacy + realistic win opportunity • Updated {{ last_updated }}
        </p>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 py-8">

    <!-- Safety -->
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6 text-sm">
      <strong class="text-amber-800">
        <i class="fas fa-exclamation-triangle mr-1"></i> Never pay to claim a prize.
      </strong>
      Real sweepstakes are free. Use a burner email.
    </div>

    <!-- Top CTAs -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      <a href="https://www.swagbucks.com/" target="_blank" rel="noopener sponsored"
         class="bg-teal-600 hover:bg-teal-700 text-white rounded-xl p-4 text-center font-semibold shadow transition">
        Start with Swagbucks → Reliable Daily Earnings
      </a>
      <a href="https://www.mondosweeps.com/" target="_blank" rel="noopener"
         class="bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl p-4 text-center font-semibold shadow transition">
        Try Mondosweeps → Best Daily $25 Chance
      </a>
      <a href="https://www.pch.com/" target="_blank" rel="noopener"
         class="bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl p-4 text-center font-semibold shadow transition">
        Enter PCH → America’s Most Trusted Big Prizes
      </a>
    </div>

    <!-- ScamFactor Header -->
    <div class="bg-white rounded-xl shadow-sm border p-5 mb-6">
      <h2 class="font-bold text-teal-800 mb-3 flex flex-wrap items-center gap-4">
        <span class="scamfactor-badge" 
              title="ScamFactor is our proprietary score (1–10). Lower is better. It measures transparency, fulfillment history, entry gotchas, realistic win odds, and marketing aggressiveness.">
          SCAMFACTOR
        </span>
        <span class="text-xs bg-red-100 text-red-700 px-3 py-1 rounded-full font-normal">
          Higher = more red flags, hidden fees, aggressive spam
        </span>
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-2 text-xs">
        <div class="bg-teal-50 p-2 rounded" title="Do they clearly show winners and official rules?">30% Transparency & Winner Proof</div>
        <div class="bg-teal-50 p-2 rounded" title="How often do people report receiving prizes vs complaints?">25% Fulfillment & Complaints</div>
        <div class="bg-teal-50 p-2 rounded" title="Are there hidden requirements, paid entries, or hard-to-find free methods?">20% Entry Model & Gotchas</div>
        <div class="bg-teal-50 p-2 rounded" title="How realistic is it to actually win something meaningful?">15% Win Opportunity Realism</div>
        <div class="bg-teal-50 p-2 rounded" title="How aggressive is the email/SMS marketing after signing up?">10% Marketing Aggressiveness</div>
      </div>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-xl shadow border overflow-x-auto mb-10">
      <table class="w-full text-sm">
        <thead>
          <tr>
            <th class="px-3 py-3 text-left" title="Overall ranking based on ScamFactor">#</th>
            <th class="px-3 py-3 text-left">Site</th>
            <th class="px-3 py-3 text-center" title="Lower score = more legitimate and better chance of a real win">ScamFactor</th>
            <th class="px-3 py-3 text-left">Prizes (examples)</th>
            <th class="px-3 py-3 text-left">Draw Frequency</th>
            <th class="px-3 py-3 text-left">Unsubscribe</th>
            <th class="px-3 py-3 text-left">Major Red Flags</th>
            <th class="px-3 py-3 text-center">Link</th>
          </tr>
        </thead>
        <tbody>
          {% for s in sites %}
          <tr class="border-b border-slate-100 hover:bg-teal-50/50">
            <td class="px-3 py-3 font-semibold text-slate-500">{{ s.rank }}</td>
            <td class="px-3 py-3 font-medium">{{ s.name }}</td>
            <td class="px-3 py-3 text-center">
              {% set score = s.score|float %}
              {% if score <= 2 %}
                <span class="score-pill score-low" title="Excellent – Low risk, transparent, realistic chances">{{ s.score }}</span>
              {% elif score <= 4 %}
                <span class="score-pill score-midlow" title="Good – Generally legitimate with minor issues">{{ s.score }}</span>
              {% elif score <= 6 %}
                <span class="score-pill score-mid" title="Average – Some red flags or aggressive marketing">{{ s.score }}</span>
              {% elif score <= 8 %}
                <span class="score-pill score-high" title="Caution – Higher risk of spam or poor fulfillment">{{ s.score }}</span>
              {% else %}
                <span class="score-pill score-danger" title="High Risk – Significant red flags or deceptive practices">{{ s.score }}</span>
              {% endif %}
            </td>
            <td class="px-3 py-3 text-xs max-w-xs">{{ s.prizes }}</td>
            <td class="px-3 py-3 text-xs">{{ s.draw }}</td>
            <td class="px-3 py-3 text-xs text-teal-700">{{ s.unsub }}</td>
            <td class="px-3 py-3 text-xs text-red-700">{{ s.redFlags }}</td>
            <td class="px-3 py-3 text-center">
              {% if s.link and s.link != "#" %}
                <a href="{{ s.link }}" target="_blank" rel="noopener" class="text-teal-600 hover:underline font-medium">Visit</a>
              {% else %}
                <span class="text-slate-400">—</span>
              {% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <footer class="text-center text-xs text-slate-500 py-6 border-t">
      Data last refreshed {{ last_updated }}. Always verify official rules on each site.<br>
      Some links may be affiliate links. Rankings are never paid.
    </footer>
  </main>
</body>
</html>
